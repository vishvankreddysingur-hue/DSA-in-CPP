class Solution {
public:
    string getSmallestString(string s) {
        string k = s;

        for (int i = 0; i < s.length() - 1; i++) {

            if ((s[i] - '0') % 2 == (s[i + 1] - '0') % 2) {

                string temp = s;
                swap(temp[i], temp[i + 1]);

                if (temp < k) {
                    k = temp;
                }
            }
        }

        return k;
    }
};
