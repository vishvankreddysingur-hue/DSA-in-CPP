class Solution {
public:
    vector<int> decompressRLElist(vector<int>& nums) {
        std::vector<int> vec; // Empty vector
        int  o = 0;
        for(int i = 0 ; i < nums.size() ; i = i + 2) {
            int l = nums[i];
            int h = nums[i + 1];
            for(int j = 0 ; j < l ; j++) {
            vec.push_back(h);
            }
        }
        return vec;
    }
};
