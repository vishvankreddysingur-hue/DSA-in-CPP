class Solution {
public:
    vector<int> getFinalState(vector<int>& nums, int k, int multiplier) {
        for (int i = 0; i < k; i++) {
            int minIdx = 0;

            for (int j = 1; j < nums.size(); j++) {
                if (nums[j] < nums[minIdx]) {
                    minIdx = j;
                }
            }

            nums[minIdx] *= multiplier;
        }

        return nums;
    }
};
