class Solution {
public:
    int majorityElement(vector<int>& nums) {
        for(int i = 0; i < nums.size(); i++) {
            int count = 0;
            int x = nums[i];
            for(int j = 0; j < nums.size(); j++) {
                if(nums[j] == x) {
                    count = count + 1;
                }
            }
            if(count > nums.size() / 2) {
                return x;
            }
        }
        return 0;
    }
};
